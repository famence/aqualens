{
  "name": "@aqualens/react",
  "version": "1.1.0",
  "description": "React bindings for @aqualens/core – A liquid glass effect components and hooks",
  "main": "dist/aqualens-react.js",
  "module": "dist/aqualens-react.mjs",
  "types": "dist/aqualens-react.d.ts",
  "exports": {
    ".": {
      "types": "./dist/aqualens-react.d.ts",
      "import": "./dist/aqualens-react.mjs",
      "require": "./dist/aqualens-react.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aqualens/core": "^1.1.0"
  },
  "peerDependencies": {
    "html2canvas-pro": "^2.0.2",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "html2canvas-pro": "^2.0.2",
    "@types/react": ">=18.0.0",
    "@types/react-dom": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/famence/aqualens.git"
  },
  "homepage": "https://famence.github.io/aqualens",
  "license": "MIT",
  "keywords": [
    "react",
    "liquid-glass",
    "effect",
    "webgl",
    "glass-effect",
    "glassmorphism",
    "ui",
    "aqualens"
  ]
}