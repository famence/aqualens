{
  "name": "@aqualens/core",
  "version": "1.0.4",
  "description": "Framework-agnostic Liquid Glass engine powered by WebGL2",
  "main": "dist/aqualens.js",
  "module": "dist/aqualens.mjs",
  "types": "dist/aqualens.d.ts",
  "exports": {
    ".": {
      "types": "./dist/aqualens.d.ts",
      "import": "./dist/aqualens.mjs",
      "require": "./dist/aqualens.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "html2canvas-pro": "^2.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/famence/aqualens.git"
  },
  "license": "MIT",
  "keywords": [
    "liquid-glass",
    "effect",
    "glass-effect",
    "webgl",
    "glassmorphism",
    "ui",
    "aqualens"
  ]
}